# Pit Wall — environment variables
# Copy this file to ".env.local" and fill in the three values.
# See DEPLOY.md for where to find each one. Never commit .env.local.

# Supabase → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Project Settings → API Keys → service_role key  (SECRET)
# Used only for file storage (uploads + signed download URLs).
SUPABASE_SERVICE_ROLE_KEY=

# Supabase → Project Settings → Database → Connection string → Transaction pooler
# Put your database password into the string. (SECRET)
# Used for all data access; Row Level Security enforces the private/shared split.
DATABASE_URL=

# --- Optional: real email push for status updates (Resend) ---------------
# Leave these blank to keep updates in-app only. Set all three to also email
# the client when a status update is generated. No code change needed.
# RESEND_API_KEY=
# NOTIFY_FROM_EMAIL=updates@yourdomain.com
# CLIENT_NOTIFY_EMAIL=client@example.com
